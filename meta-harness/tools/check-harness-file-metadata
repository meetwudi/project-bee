#!/usr/bin/env python3
import argparse
import sys
from pathlib import Path


ALLOWED_CHANGE_VALUES = {"explicit_human_request"}


def normalize(path):
    return path.strip().replace("\\", "/").lstrip("./")


def read_changed_files(path):
    return [normalize(line) for line in Path(path).read_text().splitlines() if line.strip()]


def markdown_files(repo_root, changed_files):
    if changed_files is not None:
        for raw_path in changed_files:
            path = repo_root / raw_path
            if path.suffix.lower() == ".md" and path.is_file():
                yield path
        return

    ignored_roots = {".git"}
    for path in sorted(repo_root.rglob("*.md")):
        if any(part in ignored_roots for part in path.relative_to(repo_root).parts):
            continue
        yield path


def parse_front_matter(text):
    lines = text.splitlines()
    if not lines or lines[0].strip() != "---":
        return None

    front_matter = []
    for line in lines[1:]:
        if line.strip() == "---":
            return front_matter
        front_matter.append(line)
    return None


def validate_harness_file(path, lines, failures):
    saw_harness_file = False
    saw_change = False
    in_harness_file = False

    for line in lines:
        stripped = line.strip()
        if not stripped or stripped.startswith("#"):
            continue

        indent = len(line) - len(line.lstrip(" "))
        if indent == 0:
            in_harness_file = False
            if stripped == "harness_file:":
                saw_harness_file = True
                in_harness_file = True
            elif stripped.startswith("harness_file:"):
                failures.append(f"{path}: harness_file must be a mapping")
            continue

        if not in_harness_file:
            continue

        if indent != 2:
            failures.append(f"{path}: harness_file fields must use two-space indentation")
            continue

        if ":" not in stripped:
            failures.append(f"{path}: invalid harness_file field: {stripped}")
            continue

        key, value = [part.strip() for part in stripped.split(":", 1)]
        if key != "change":
            failures.append(f"{path}: unsupported harness_file field: {key}")
            continue

        saw_change = True
        if value not in ALLOWED_CHANGE_VALUES:
            failures.append(
                f"{path}: harness_file.change must be one of {sorted(ALLOWED_CHANGE_VALUES)}"
            )

    if saw_harness_file and not saw_change:
        failures.append(f"{path}: harness_file.change is required")


def validate_file(repo_root, path, failures):
    relative = normalize(str(path.relative_to(repo_root)))
    try:
        text = path.read_text()
    except UnicodeDecodeError as exc:
        failures.append(f"{relative}: could not read as text: {exc}")
        return

    front_matter = parse_front_matter(text)
    if front_matter is None:
        return

    if any(line.strip().startswith("harness_file") for line in front_matter):
        validate_harness_file(relative, front_matter, failures)


def main():
    parser = argparse.ArgumentParser(
        description="Verify Meta Harness harness_file Markdown front matter."
    )
    parser.add_argument("--repo-root", default=".")
    parser.add_argument("--changed-files")
    args = parser.parse_args()

    repo_root = Path(args.repo_root).resolve()
    changed_files = read_changed_files(args.changed_files) if args.changed_files else None
    failures = []
    count = 0

    for path in markdown_files(repo_root, changed_files):
        validate_file(repo_root, path, failures)
        count += 1

    if failures:
        print("Meta Harness file metadata check failed:", file=sys.stderr)
        for failure in failures:
            print(f"- {failure}", file=sys.stderr)
        return 1

    print(f"Meta Harness file metadata passed for {count} Markdown file(s).")
    return 0


if __name__ == "__main__":
    sys.exit(main())
